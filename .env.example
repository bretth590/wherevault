# Database (Vercel Postgres / Neon / any PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wherevault?schema=public"

# JWT
JWT_SECRET="change-me-to-a-secure-random-string"

# Encryption (32-byte hex key for AES-256-GCM)
VAULT_ENCRYPTION_KEY="change-me-32-byte-hex-key-here"

# Refresh tokens
REFRESH_TOKEN_EXPIRES_DAYS="30"

# Email (Resend - optional, falls back to console logging)
RESEND_API_KEY=""
FROM_EMAIL="noreply@wherevault.app"

# App URL (for email links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron secret (for Vercel cron jobs)
CRON_SECRET="change-me-to-a-secure-random-string"
